# Database
DATABASE_URL="postgresql://username:password@localhost:5432/sablia_db"

# Environment
NODE_ENV="development"

# Optionnel : Variables pour le frontend (préfixées par VITE_)
# VITE_API_URL="http://localhost:5000"

# Google Analytics 4 (leave commented out in dev — GA4 is disabled when absent)
# VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Ads Conversion Tracking (leave commented out until conversion actions created)
# VITE_GADS_CONVERSION_ID="AW-XXXXXXXXX"
# VITE_GADS_LABEL_CONTACT="<label>"
# VITE_GADS_LABEL_GAP="<label>"
# VITE_GADS_LABEL_CALENDLY="<label>"
# VITE_GADS_LABEL_DIAGNOSTIC="<label>"

# n8n webhooks (leave commented out in dev — falls back to prod URLs hardcoded in form-constants.ts)
# VITE_CONTACT_WEBHOOK_URL="https://n8n.sablia.io/webhook/sablia-site-formulaire"
# VITE_GAP_WEBHOOK_URL="https://n8n.sablia.io/webhook/sablia-site-gap"
# VITE_DIAGNOSTIC_WEBHOOK_URL="https://n8n.sablia.io/webhook/sablia-site-diagnostic"